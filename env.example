# Environment variables example
# Copy this file to .env and fill in your values

# Django settings
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=unsafe-development-key-change-me
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# Database used by run, scanner, scan, and makemigrations via your .env & .env.docker
# Choose PostgreSQL:
# DATABASE_URL=postgres://sopds:sopds@127.0.0.1:5432/sopds
# Or choose MySQL/MariaDB:
# DATABASE_URL=mysql://root:sopds@127.0.0.1:3306/sopds?charset=utf8mb4&collation=utf8mb4_nopad_bin

# Both databases are used by make test and make migrate.
DATABASE_URL_POSTGRESQL=postgres://sopds:sopds@127.0.0.1:5432/sopds
DATABASE_URL_MYSQL=mysql://root:sopds@127.0.0.1:3306/sopds?charset=utf8mb4&collation=utf8mb4_nopad_bin

# Host and port for the application
HOST=0.0.0.0
PORT=8000
GUNICORN_WORKERS=2

# Superuser settings
DJANGO_SUPERUSER_USERNAME=root
DJANGO_SUPERUSER_PASSWORD=Ab,12345
DJANGO_SUPERUSER_EMAIL=root@localhost

# SOPDS config knobs (override constance defaults via env)
SOPDS_TEMP_DIR=/tmp
SOPDS_ROOT_LIB=books/
SOPDS_ZIP_ENABLE=True
SOPDS_ZIP_CODEPAGE=cp866
SOPDS_DELETE_LOGICAL=True
SOPDS_INPX_ENABLE=True
SOPDS_INPX_SKIP_UNCHANGED=False
SOPDS_INPX_TEST_ZIP=False
SOPDS_INPX_TEST_FILES=False
SOPDS_SCAN_START_DIRECTLY=False
