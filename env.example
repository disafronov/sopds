# Environment variables example
# Copy this file to .env and fill in your values

# Django settings
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=unsafe-development-key-change-me
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=

# Database settings
# For local development with PostgreSQL:
DATABASE_URL=postgres://sopds:sopds@127.0.0.1:5432/sopds
# For local development with MySQL/MariaDB:
# DATABASE_URL=mysql://sopds:sopds@127.0.0.1:3306/sopds

# Host and port for the application
HOST=0.0.0.0
PORT=8000
GUNICORN_WORKERS=2

# Superuser settings
DJANGO_SUPERUSER_USERNAME=root
DJANGO_SUPERUSER_PASSWORD=Ab,12345
DJANGO_SUPERUSER_EMAIL=root@localhost

# SOPDS config knobs (override constance defaults via env)
SOPDS_ROOT_LIB=books/
SOPDS_ZIPSCAN=True
SOPDS_ZIPCODEPAGE=cp866
SOPDS_DELETE_LOGICAL=True
SOPDS_INPX_ENABLE=True
SOPDS_INPX_SKIP_UNCHANGED=False
SOPDS_INPX_TEST_ZIP=False
SOPDS_INPX_TEST_FILES=False
SOPDS_SCAN_START_DIRECTLY=False
