# Environment variables example
# Copy this file to .env and fill in your values

# Django settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=0.0.0.0

# Database settings
# Default: local SQLite file
DATABASE_URL=sqlite:///db.sqlite3
# For local development with compose.yml (Postgres service):
# DATABASE_URL=postgres://sopds:sopds@host.docker.internal:5432/sopds

# Host and port for the application
HOST=0.0.0.0
PORT=8000

# SOPDS settings
SOPDS_USER=root
SOPDS_EMAIL=root@localhost
SOPDS_PASSWORD=Ab,12345
