{
  "name": "sopds-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "SOPDS frontend assets",
  "scripts": {
    "build": "npm run build:css && npm run build:vendor",
    "build:css": "sass --quiet-deps --load-path=node_modules/foundation-sites/scss --load-path=node_modules/motion-ui/src --style=compressed --no-source-map scss/sopds.scss:../../web_backend/static/css/sopds.css",
    "build:vendor": "node scripts/copy-vendor.mjs",
    "dev": "npm run build:vendor && npm run watch:css",
    "watch:css": "sass --quiet-deps --load-path=node_modules/foundation-sites/scss --load-path=node_modules/motion-ui/src --style=compressed --no-source-map --watch scss/sopds.scss:../../web_backend/static/css/sopds.css",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "foundation-sites": "6.9.0",
    "jquery": "4.0.0",
    "motion-ui": "2.0.8",
    "what-input": "5.2.12"
  },
  "devDependencies": {
    "jsdom": "29.1.1",
    "sass": "1.101.7"
  },
  "engines": {
    "node": ">=24"
  }
}
