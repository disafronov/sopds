DATABASE_URL=postgres://sopds:sopds@host.docker.internal:5432/sopds
DJANGO_ALLOWED_HOSTS=*
SOPDS_ROOT_LIB=/books
SOPDS_ZIPSCAN=True
SOPDS_ZIPCODEPAGE=utf-8
SOPDS_DELETE_LOGICAL=True
SOPDS_INPX_ENABLE=True
SOPDS_INPX_SKIP_UNCHANGED=True
SOPDS_INPX_TEST_ZIP=True
SOPDS_INPX_TEST_FILES=True
SOPDS_SCAN_START_DIRECTLY=True

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=password
