[{"model":"opds_catalog.book","pk":5,"fields":{"filename":"262001.fb2","filesize":503533,"format":"fb2","catalog":3,"registerdate":"2016-11-19T05:53:55.469Z","docdate":"30.1.2011","lang":"en","title":"The Sanctuary Sparrow","annotation":"","lang_code":2,"avail":2}},{"model":"opds_catalog.book","pk":6,"fields":{"filename":"539603.fb2","filesize":15194,"format":"fb2","catalog":4,"registerdate":"2016-11-19T05:53:55.543Z","docdate":"130552595662030000","lang":"ru","title":"Любовь в жизни Обломова","annotation":"Лет тому восемь назад представитель какого-то сибирского университета обратился ко мне с просьбой написать сочинение, наподобие тех, что пишут школьники. Мне предложили взять любое произведение из школьной программы и разобрать «образ» любого из персонажей. Предложение показалось интересным, и я согласился. Написал сочинение по роману Ивана Гончарова «Обломов» и даже получил за него какую-то денежку. Экземпляра сборника мне так и не прислали.\nИ вот теперь нашёл я среди замшелых файлов этот текст и предлагаю вашему благосклонному вниманию. Мне кажется, текст достаточно любопытен.","lang_code":1,"avail":2}},{"model":"opds_catalog.book","pk":7,"fields":{"filename":"539485.fb2","filesize":12293,"format":"fb2","catalog":4,"registerdate":"2016-11-19T05:53:55.584Z","docdate":"2010-07-23 09:35:56","lang":"bg","title":"Китайски сладкиш с късметче","annotation":"","lang_code":1,"avail":2}},{"model":"opds_catalog.book","pk":8,"fields":{"filename":"539273.fb2","filesize":21722,"format":"fb2","catalog":4,"registerdate":"2016-11-19T05:53:55.629Z","docdate":"2014-06-11 08:25:05","lang":"ru","title":"Драконьи Услуги","annotation":"Очередная попытка изучить отношение драконов и принцесс. Ведь это настолько сложная тема, что можно представить всё что угодно. Например то, что драконы существуют для того, что бы принцессы поднимали свою самооценку.","lang_code":1,"avail":2}},{"model":"opds_catalog.catalog","pk":3,"fields":{"parent":null,"cat_name":".","path":".","cat_type":0,"cat_s